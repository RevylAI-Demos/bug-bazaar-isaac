{
  "expo": {
    "name": "bug-bazaar",
    "slug": "bug-bazaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "bug-bazaar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2AD85C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bugbazaar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bugbazaar.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/launch-args-module.js",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "28ff01c5-9dbb-40a6-8d8a-d309ecc1dee7"
      }
    },
    "owner": "issc29"
  }
}
